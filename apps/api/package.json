{
	"name": "@zemio/api",
	"version": "1.0.0-alpha.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write ."
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.975.0",
		"@aws-sdk/s3-request-presigner": "^3.1029.0",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@zemio/db": "workspace:*",
		"@zemio/encryption": "workspace:*",
		"date-fns": "^4.1.0",
		"heic-convert": "^2.1.0",
		"hono": "^4",
		"pdf-lib": "^1.17.1",
		"pdfkit": "^0.17.1",
		"pg": "^8.13.3",
		"sharp": "^0.34.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@types/bun": "latest",
		"@types/heic-convert": "^2.1.1",
		"@types/pdfkit": "^0.17.4",
		"@types/pg": "^8",
		"@zemio/typescript-config": "workspace:*",
		"typescript": "^5.8.2"
	}
}
