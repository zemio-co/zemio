{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"generate": {
			"outputs": ["src/generated/**"]
		},
		"build": {
			"dependsOn": ["^build", "generate"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"],
			"passThroughEnv": ["SKIP_ENV_VALIDATION"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": ["tsconfig.tsbuildinfo"]
		},
		"check": {
			"outputs": []
		}
	}
}
