# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.js

# testing
/coverage

# database
db.sqlite
apps/web/prisma/db.sqlite
apps/web/prisma/db.sqlite-journal

# next.js
apps/web/.next/
apps/web/out/
apps/web/next-env.d.ts

# production
/build

# compiled package output (built by turbo / CI / Docker)
packages/*/dist

# turborepo
.turbo/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
# do not commit any .env files to git, except for the .env.example file. https://create.t3.gg/en/usage/env-variables#using-environment-variables
.env
.env*.local
.env.prod

# config files
# do not commit config.ts (contains instance-specific settings)
# config.example.ts is the template and should be committed
config.ts
config.js

# vercel
.vercel

# typescript
*.tsbuildinfo

# idea files
.idea

# uploads
apps/web/public/uploads

# Sentry Config File
.env.sentry-build-plugin

# AI agent tooling (personal developer config)
.agents/
.claude/
